<?xml version="1.0" encoding="utf-8"?>
<selector android:shape="oval"
  xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <gradient android:startColor="#ff267152" android:endColor="#ff8e7e2f" android:angle="0.0" android:centerColor="#ff91993a" />
            <corners android:radius="100.0dip" />
        </shape>
    </item>
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <gradient android:startColor="#ff267152" android:endColor="#ff8e7e2f" android:angle="0.0" android:centerColor="#ff91993a" />
            <corners android:radius="100.0dip" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient android:startColor="#ff3ab987" android:endColor="#fffae065" android:angle="0.0" android:centerColor="#ffcbd653" />
            <corners android:radius="100.0dip" />
        </shape>
    </item>
</selector>