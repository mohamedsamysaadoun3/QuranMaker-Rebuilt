<?xml version="1.0" encoding="utf-8"?>
<selector
  xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <gradient android:startColor="#b74e1c6f" android:endColor="#bca95d1e" android:angle="0.0" android:type="linear" android:centerColor="#bcd1701f" />
            <corners android:radius="15.0dip" />
        </shape>
    </item>
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <gradient android:startColor="#b74e1c6f" android:endColor="#bca95d1e" android:angle="0.0" android:type="linear" android:centerColor="#bcd1701f" />
            <corners android:radius="15.0dip" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient android:startColor="#b7833ab4" android:endColor="#bcf58529" android:angle="0.0" android:type="linear" android:centerColor="#bcf58529" />
            <corners android:radius="15.0dip" />
        </shape>
    </item>
</selector>