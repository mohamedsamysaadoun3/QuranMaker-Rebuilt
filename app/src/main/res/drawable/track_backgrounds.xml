<?xml version="1.0" encoding="utf-8"?>
<selector
  xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_checked="true">
        <shape android:shape="rectangle">
            <solid android:color="#ffe91e63" />
            <corners android:radius="100.0dip" />
            <stroke android:width="2.0dip" android:color="#ff2196f3" />
            <size android:height="20.0dip" />
        </shape>
    </item>
    <item android:state_checked="false">
        <shape android:shape="rectangle">
            <solid android:color="#ffffeb3b" />
            <corners android:radius="100.0dip" />
            <stroke android:width="2.0dip" android:color="#ffff9800" />
            <size android:height="20.0dip" />
        </shape>
    </item>
</selector>