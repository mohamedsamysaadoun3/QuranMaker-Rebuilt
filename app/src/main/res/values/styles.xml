<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="App.VideoPlayer" parent="@style/Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowTranslucentStatus">true</item>
        <item name="android:windowTranslucentNavigation">true</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>
    <style name="Base.Theme.NurMontage" parent="@style/Theme.Material3.Light.NoActionBar" />
    <style name="Theme.App.Fullscreen" parent="@style/Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowActionBar">false</item>
        <item name="android:windowTranslucentStatus">false</item>
        <item name="android:windowTranslucentNavigation">false</item>
    </style>
    <style name="AyaPresetButton">
        <item name="android:textSize">12.0sp</item>
        <item name="android:textColor">#ffffffff</item>
        <item name="android:gravity">center</item>
        <item name="android:background">@drawable/bg_preset_btn</item>
        <item name="android:focusable">true</item>
        <item name="android:clickable">true</item>
        <item name="android:layout_width">72.0dip</item>
        <item name="android:layout_height">36.0dip</item>
        <item name="android:layout_marginEnd">6.0dip</item>
    </style>
    <style name="CustomSeekBarStyle" parent="@style/Widget.AppCompat.SeekBar">
        <item name="android:maxHeight">4.0dip</item>
        <item name="android:progressDrawable">@drawable/custom_track</item>
        <item name="android:thumb">@drawable/custom_thumb</item>
    </style>
    <style name="Theme.NurMontage" parent="@style/Base.Theme.NurMontage" />
    <style name="Theme.NurMontage.Fullscreen" parent="@style/Theme.NurMontage">
        <item name="android:windowBackground">@null</item>
        <item name="android:actionBarStyle">@style/Widget.Theme.SDin1224.ActionBar.Fullscreen</item>
        <item name="android:windowActionBarOverlay">true</item>
    </style>
    <style name="Theme.NurMontage.Starting" parent="@style/Theme.SplashScreen">
        <item name="postSplashScreenTheme">@style/Theme.NurMontage</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/nurmontage_splach</item>
        <item name="windowSplashScreenBackground">@color/white</item>
    </style>
    <style name="ThemeOverlay.NurMontage.FullscreenContainer" parent="">
        <item name="fullscreenBackgroundColor">@color/light_blue_600</item>
        <item name="fullscreenTextColor">@color/light_blue_A200</item>
    </style>
    <style name="Widget.Theme.SDin1224.ActionBar.Fullscreen" parent="@style/Widget.AppCompat.ActionBar">
        <item name="android:background">@color/black_overlay</item>
    </style>
    <style name="Widget.Theme.SDin1224.ButtonBar.Fullscreen" parent="">
        <item name="android:background">@color/black_overlay</item>
        <item name="android:buttonBarStyle">?android:buttonBarStyle</item>
    </style>
</resources>
