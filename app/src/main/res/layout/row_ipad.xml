<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:background="@drawable/round_btn_quran"
    android:focusable="true"
    android:clickable="true"
    android:layout_width="70dp"
    android:layout_height="70dp"
    android:layout_margin="4dp">
    <ImageView
        android:id="@+id/img"
        android:padding="5dp"
        android:focusable="false"
        android:clickable="false"
        android:layout_width="70dp"
        android:layout_height="70dp" />
    <ImageView
        android:id="@+id/iv_pro"
        android:focusable="false"
        android:visibility="gone"
        android:clickable="false"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:layout_margin="5dp"
        android:src="@drawable/crown_24px"
        android:layout_alignParentRight="true"
        android:layout_alignParentBottom="true"
        android:layout_alignParentEnd="true" />
    <LinearLayout
        android:orientation="horizontal"
        android:id="@+id/view_option"
        android:background="@drawable/oval_transparent"
        android:padding="2dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true">
        <View
            android:id="@+id/dot1"
            android:background="@drawable/bg_indicator_dot"
            android:layout_width="6dp"
            android:layout_height="6dp"
            android:layout_margin="5dp" />
        <View
            android:id="@+id/dot2"
            android:background="@drawable/bg_indicator_dot"
            android:layout_width="6dp"
            android:layout_height="6dp"
            android:layout_margin="5dp" />
    </LinearLayout>
</RelativeLayout>
